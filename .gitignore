# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/playwright-report/*
!/playwright-report/.gitkeep
/test-results/*
!/test-results/.gitkeep
/playwright/.auth/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# graphify generated knowledge graph output
graphify-out/

# local Codex/GSD/security workflow installs and scratch plans
.agent/*
!.agent/CONTINUITY.md
.agent/tools/
docs/archived-codex-thread-*.md
.codex/get-shit-done/
.codex/skills/gsd-*/
.codex/gsd-file-manifest.json
.codex/VERSION
.codex/package.json
.planning/

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# local Supabase CLI artifacts
supabase/.branches/
supabase/.temp/
supabase/config.toml
supabase/public-schema.sql

# typescript
*.tsbuildinfo
next-env.d.ts
