{
  "name": "secret-santa-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "start:e2e": "next start --hostname 127.0.0.1 --port 3000",
    "lint": "eslint app lib utils scripts tests *.ts *.mjs --no-error-on-unmatched-pattern",
    "lint:security": "eslint app lib utils scripts tests *.ts *.mjs --max-warnings=0 --no-error-on-unmatched-pattern",
    "check:problems": "node ./scripts/check-vscode-problems.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "typecheck": "tsc --noEmit",
    "prepare": "node ./scripts/prepare-husky.mjs",
    "import:lazada-feed": "powershell -ExecutionPolicy Bypass -File ./scripts/import-lazada-feed.ps1"
  },
  "dependencies": {
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.99.1",
    "next": "16.2.3",
    "react": "19.2.5",
    "react-dom": "19.2.5"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20.19.37",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "eslint-plugin-no-secrets": "^2.3.3",
    "eslint-plugin-security": "^4.0.0",
    "supabase": "^2.92.1",
    "tailwindcss": "^4.2.2",
    "typescript": "^5"
  }
}
