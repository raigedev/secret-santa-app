{
  "name": "secret-santa-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "start:e2e": "next start --hostname 127.0.0.1 --port 3000",
    "seed:e2e:local": "node ./scripts/repair-local-supabase-schema.mjs && node ./scripts/seed-local-playwright.mjs",
    "test:security": "node --test tests/security-remediation.test.mjs",
    "lint": "eslint app lib utils scripts tests *.ts *.mjs --no-error-on-unmatched-pattern",
    "lint:security": "eslint app lib utils scripts tests *.ts *.mjs --max-warnings=0 --no-error-on-unmatched-pattern",
    "check:problems": "node ./scripts/check-vscode-problems.mjs",
    "audit:architecture": "depcruise --config .dependency-cruiser.cjs --output-type err app lib scripts tests",
    "audit:security": "npm audit --audit-level=high",
    "audit:unused": "knip --reporter compact --no-exit-code",
    "audit:unused:production": "knip --production --reporter compact --no-exit-code",
    "analyze:bundle": "next experimental-analyze --output",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report",
    "typecheck": "tsc --noEmit",
    "prepare": "node ./scripts/prepare-husky.mjs",
    "import:lazada-feed": "powershell -ExecutionPolicy Bypass -File ./scripts/import-lazada-feed.ps1"
  },
  "dependencies": {
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.105.3",
    "next": "16.2.6",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "server-only": "^0.0.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^20.19.39",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dependency-cruiser": "^17.4.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "eslint-plugin-no-secrets": "^2.3.3",
    "eslint-plugin-security": "^4.0.0",
    "knip": "^6.11.0",
    "postcss": "^8.5.14",
    "supabase": "^2.98.1",
    "tailwindcss": "^4.2.4",
    "typescript": "^5"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.14"
    }
  }
}
